# ─── REQUIRED ──────────────────────────────────────────────────────────────
# Supabase project (managed Postgres). The service-role key is used because
# the backend writes from the chain indexer and snapshot fetcher; no end-user
# auth touches this service. Do NOT expose the service-role key to the
# frontend.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 0G Galileo testnet RPC. Indexer reads chain events from here.
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage testnet indexer. Used by the snapshot fetcher to download
# blob JSON for snapshots seen on-chain.
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ─── OPTIONAL ──────────────────────────────────────────────────────────────
# HTTP port the Fastify server listens on. Frontend NEXT_PUBLIC_API_URL
# points at this.
PORT=4000
