# URL of the backend Fastify API. In local dev this is the `backend`
# package running on PORT (default 4000). In prod, point at the deployed
# Railway/Fly host (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:4000

# 0G Galileo testnet RPC. Privy embedded wallets use this to read state
# and send transactions.
NEXT_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai

# Privy app ID from https://dashboard.privy.io/. Allowed origins on the
# Privy side must include this frontend's URL.
NEXT_PUBLIC_PRIVY_APP_ID=__PASTE_PRIVY_APP_ID__
