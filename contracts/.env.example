# ─── REQUIRED ──────────────────────────────────────────────────────────────
# Operator deployer. Must be funded on Galileo (~0.1 0G covers Deploy +
# SeedDemo with margin at the 5 gwei legacy floor).
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# 0G Galileo testnet (16602). Mainnet (16661) requires a separate deploy.
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# DASigners precompile address (constant on 0G chains).
DASIGNERS=0x0000000000000000000000000000000000001000

# Public secp256k1 key that SeedDemo.s.sol registers as the initial brain
# pubkey for every iNFT it mints. Uncompressed, 0x04-prefixed (65 bytes).
# Re-keying happens on transfer, so any pubkey you control works here.
BRAIN_PUBKEY=0x04...

# ─── FILLED IN BY THE DEPLOY SCRIPTS (do not pre-fill) ─────────────────────
# Deploy.s.sol writes these to contracts/deployments/testnet.json. Other
# packages (runtime, backend) read from that JSON, not from these env vars.
# They are listed here so dotenv doesn't warn about unknown keys when
# re-running scripts.
UNI_FACTORY=
UNI_ROUTER=
DUSD=
DRISK=
REGISTRY=
ACC_IMPL=
INFT2=
CTRL=
