# ─── REQUIRED ──────────────────────────────────────────────────────────────
# Operator wallet — signs intents, deploys snapshots, registers brain keys.
# This wallet must own all the iNFTs in the demo subtree (SeedDemo.s.sol
# mints to it). Fund it with ~0.1 0G on Galileo.
PRIVATE_KEY=0xYOUR_OPERATOR_PRIVATE_KEY

# 0G Galileo testnet RPC. The public endpoint works; rate limits apply.
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage testnet indexer.
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute Router (OpenAI-compatible).
ROUTER_URL=https://router-api.0g.ai/v1

# 0G Compute API key. Get one at https://router-api.0g.ai (signup).
ZG_API_KEY=YOUR_0G_COMPUTE_ROUTER_KEY

# ─── REQUIRED: Token IDs from SeedDemo.s.sol ───────────────────────────────
# These MUST match the ids printed by `forge script SeedDemo.s.sol --broadcast`
# (canonical record: contracts/deployments/testnet.json).
MANAGER_ID=2
MOM_ID=3
MR_ID=4
MM_ID=5

# ─── OPTIONAL: Ledger writes ───────────────────────────────────────────────
# Without these the runtime still ticks, but PnL chart + equity series + tick
# log are not persisted (the backend will have no data to serve).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── OPTIONAL: DEX trading ─────────────────────────────────────────────────
# If unset, the runtime runs in price-walk mode — strategies still emit
# decisions and ticks are logged, but no swap intents are submitted on-chain.
# DUSD, DRISK come from DeployDEX.s.sol (mock USD/risk tokens), UNI_ROUTER
# is the Uniswap V2 router on Galileo if you deploy one.
DUSD=0x0000000000000000000000000000000000000000
DRISK=0x0000000000000000000000000000000000000000
UNI_ROUTER=0x0000000000000000000000000000000000000000

# ─── OPTIONAL: tuning ──────────────────────────────────────────────────────
# Tick cadence in milliseconds. Default 60s. Use 10000 for local testing.
TICK_INTERVAL_MS=60000

# Manager snapshot publication cadence in milliseconds. Default 6h.
SNAPSHOT_EVERY_MS=21600000

# pino log level.
LOG_LEVEL=info

# Synthetic price walk seed (deterministic when DEX not configured).
MARKET_SEED=1

# Force the in-memory content-addressed storage stub (instead of trying
# the live 0G Storage SDK first and falling back on failure). Set to "true"
# only if you know you cannot upload — e.g., the Galileo flow selector
# mismatch documented in README §11.
STORAGE_STUB=false
